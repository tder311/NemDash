# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True
LOG_LEVEL=info

# Database configuration (PostgreSQL required)
# Use docker-compose up to start a local PostgreSQL instance
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/nem_dashboard

# NEMWEB API configuration
NEM_API_BASE_URL=https://www.nemweb.com.au

# Data ingestion configuration
UPDATE_INTERVAL_MINUTES=5
BACKFILL_DAYS_ON_STARTUP=30

# Conversational agent (Ask NemDash chat tab) — OpenAI
OPENAI_API_KEY=sk-...                  # required for the chat tab
OPENAI_MODEL=gpt-4o                    # optional; defaults to gpt-4o
# OPENAI_BASE_URL=https://...          # optional; for Azure / proxy / compatible endpoints
